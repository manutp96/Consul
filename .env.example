# ============================================
# RH Tramites Consulares - Variables de Entorno
# ============================================

# --- Bot de Citas (existente) ---
SHOW_BROWSER=false
ENABLE_CITA_BOT=true

# --- Discord ---
ENABLE_DISCORD=true
DISCORD_TOKEN=tu_token_del_bot_de_discord
DISCORD_CHANNEL_ID=id_del_canal_de_notificaciones
DISCORD_GUILD_ID=id_del_servidor_opcional_para_sync_rapido

# --- Claude AI ---
ANTHROPIC_API_KEY=tu_api_key_de_anthropic
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- API Server ---
ENABLE_API=true
PORT=8000
API_SECRET_KEY=una_clave_secreta_aleatoria

# --- WhatsApp (Meta Cloud API) ---
WHATSAPP_TOKEN=tu_token_de_meta
WHATSAPP_PHONE_ID=id_del_telefono_whatsapp_business
WHATSAPP_VERIFY_TOKEN=rh_tramites_verify_2024

# --- Canales WhatsApp en Discord (multi-canal) ---
# Configurar 1, 2 o 3 canales para distribuir la carga
DISCORD_WA_CHANNEL_1=id_del_canal_whatsapp_1
DISCORD_WA_CHANNEL_2=id_del_canal_whatsapp_2
DISCORD_WA_CHANNEL_3=id_del_canal_whatsapp_3
# Backward compat: si no hay canales nuevos, usar el viejo
# DISCORD_WHATSAPP_CHANNEL_ID=id_del_canal_unico

# --- Rate Limiting ---
AI_RATE_LIMIT=20
